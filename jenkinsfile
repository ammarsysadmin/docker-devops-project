pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/ammarsysadmin/docker-devops-project.git'
            }
        }

        stage('Build') {
            steps {
                sh 'docker-compose build'
            }
        }

        stage('Security Scan') {
            steps {
                sh '''
                trivy image --exit-code 1 --severity CRITICAL docker-devops-project_backend
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh 'docker-compose up -d --build'
            }
        }

        stage('Health Check') {
            steps {
                sh 'curl -f http://localhost:5001/health'
            }
        }
    }
}

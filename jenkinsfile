pipeline {
    agent any

    environment {
        DOCKER_IMAGE_BACKEND = "ammarsysadmin/backend:v3"
        DOCKER_IMAGE_FRONTEND = "ammarsysadmin/frontend:v2"
    }

    stages {

        stage('Clone Code') {
    steps {
        git branch: 'main', url: 'https://github.com/ammarsysadmin/fullstack-devops-pipeline.git'
    }
}

        stage('Build Images') {
            steps {
                sh '''
                docker build -t $DOCKER_IMAGE_BACKEND ./backend
                docker build -t $DOCKER_IMAGE_FRONTEND ./frontend
                '''
            }
        }

        stage('Push to DockerHub') {
            steps {
                sh '''
                docker push $DOCKER_IMAGE_BACKEND
                docker push $DOCKER_IMAGE_FRONTEND
                '''
            }
        }

        stage('Deploy to Kubernetes (Helm)') {
            steps {
                sh '''
                helm upgrade --install devops-release ./devops-chart \
                -n devops-project --create-namespace
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh 'kubectl get pods -n devops-project'
            }
        }
    }
}
